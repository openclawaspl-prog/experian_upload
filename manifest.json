{
  "manifest_version": 3,
  "name": "Experian Dispute Automation",
  "version": "1.0.0",
  "description": "Automates Experian dispute form submission — fetch CRM data, upload PDF, fill form.",
  "permissions": [
    "downloads",
    "storage",
    "unlimitedStorage",
    "tabs",
    "scripting",
    "activeTab",
    "alarms"
  ],
  "host_permissions": [
    "https://crm.creditfreedomrestoration.com/*",
    "https://www.experian.com/*",
    "http://207.244.236.188/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.experian.com/consumer/upload*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Experian Dispute Automation",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}